{
  "manifest_version": 3,
  "name": "Smart Task Hub",
  "version": "1.0.0",
  "description": "AI-native calendar todo app with GitHub integration",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.azurewebsites.net/*",
    "http://localhost:3000/*"
  ]
}
